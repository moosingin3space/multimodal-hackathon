# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# From the Gradient AI Platform → Serverless Inference tab
GRADIENT_MODEL_ACCESS_KEY=

# DigitalOcean personal access token
# Required scopes: genai (create, read, update, delete) + project (read)
DIGITALOCEAN_API_TOKEN=

# Optional: UUID of a Gradient Knowledge Base for RAG
# DIGITALOCEAN_KB_UUID=

# Unkey (API key management)
UNKEY_API_ID=
UNKEY_ROOT_KEY=

# Backend
DEV_API_KEY=dev
FRONTEND_URL=http://localhost:5173

# Frontend (Vite)
VITE_API_KEY=dev
