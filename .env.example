# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# DigitalOcean Gradient — from Gradient AI Platform → Serverless Inference tab
GRADIENT_MODEL_ACCESS_KEY=

# DigitalOcean personal access token (genai CRUD + project read scopes)
DIGITALOCEAN_API_TOKEN=

# Google Gemini (for image analysis) — from aistudio.google.com
GEMINI_API_KEY=

# GitHub personal access token (optional — increases rate limits 60→5000 req/hr)
GITHUB_TOKEN=

# Unkey (API key management)
UNKEY_API_ID=
UNKEY_ROOT_KEY=

# Senso.ai (persistent memory — optional, falls back to local JSON)
SENSO_API_KEY=

# Backend
DEV_API_KEY=dev
FRONTEND_URL=http://localhost:5173
SCOUT_DATA_DIR=data

# Frontend (Vite)
VITE_API_KEY=dev
VITE_API_BASE_URL=http://localhost:8000
